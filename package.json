{
  "name": "whatdat",
  "version": "0.15.1",
  "description": "What Dat?!?",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "vite build",
    "clean": "rm -rf ./build",
    "dev": "npx vite serve",
    "format": "npx oxfmt src",
    "format:check": "npx oxfmt --check src",
    "lint": "npx oxlint src",
    "prebuild": "npm run clean",
    "preview": "npx vite preview",
    "test": "npm run lint && npm run format:check",
    "ver:bump": "npm version --git-tag-version false",
    "ver:patch": "npm run ver:bump -- patch && npm run ver:tag && npm run ver:publish",
    "ver:minor": "npm run ver:bump -- minor && npm run ver:tag && npm run ver:publish",
    "ver:major": "npm run ver:bump -- major && npm run ver:tag && npm run ver:publish",
    "ver:publish": "git push --all && git push --tags",
    "ver:tag": "APP_VERSION=$(node -e 'console.log(process.env.npm_package_version)') && git add package.json package-lock.json && git commit -m \"chore(release): bump version v$APP_VERSION\" && git tag $APP_VERSION -m \"chore(release): v$APP_VERSION\""
  },
  "author": {
    "name": "Michael Sprague",
    "email": "mikesprague@gmail.com"
  },
  "repository": "github:mikesprague/whatdat",
  "license": "MIT",
  "engines": {
    "node": ">= 24.x",
    "npm": ">= 11.x"
  },
  "packageManager": "npm@11.17.0",
  "dependencies": {
    "@bugsnag/js": "8.9.0",
    "@fortawesome/fontawesome-svg-core": "7.3.0",
    "@fortawesome/pro-duotone-svg-icons": "7.3.0",
    "@tensorflow-models/coco-ssd": "2.2.3",
    "@tensorflow-models/mobilenet": "2.1.1",
    "@tensorflow/tfjs": "4.22.0",
    "@tensorflow/tfjs-backend-cpu": "4.22.0",
    "@tensorflow/tfjs-backend-webgl": "4.22.0",
    "@tensorflow/tfjs-converter": "4.22.0",
    "@tensorflow/tfjs-core": "4.22.0",
    "bootstrap": "5.3.8",
    "bootswatch": "5.3.8",
    "fabric": "7.4.0",
    "html2canvas": "1.4.1",
    "logrocket": "12.1.1",
    "sweetalert2": "11.26.25",
    "tippy.js": "6.3.7"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "8.0.0",
    "autoprefixer": "10.5.2",
    "cross-env": "10.1.0",
    "cssnano": "8.0.2",
    "cz-git": "1.13.1",
    "oxfmt": "0.56.0",
    "oxlint": "1.72.0",
    "postcss": "8.5.16",
    "sass": "1.101.0",
    "seedrandom": "3.0.5",
    "vite": "8.1.1",
    "vite-plugin-pwa": "1.3.0"
  },
  "overrides": {
    "@isaacs/brace-expansion": "^5.0.1",
    "ajv": "^8.20.0",
    "glob": "^13.0.6",
    "serialize-javascript": "^7.0.6"
  },
  "browserslist": {
    "development": [
      "last 1 version"
    ],
    "production": [
      "> 1%",
      "last 2 versions",
      "not ie <= 10"
    ]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-git"
    }
  },
  "volta": {
    "node": "26.3.1",
    "npm": "11.17.0"
  }
}
